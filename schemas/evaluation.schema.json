{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evaluation",
  "type": "object",
  "properties": {
    "applicant_id": { "type": "string" },
    "overall_summary": { "type": "string" },
    "ai_recommendation": { 
      "type": "string", 
      "enum": ["Accept", "Reject", "Additional info needed"],
      "description": "A suggested decision for the human reviewer based on the initial AI analysis."
    },
    "ai_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "topic": { "type": "string" },
          "reason": { "type": "string", "description": "Why this is flagged (e.g., 'Assumption', 'Uncertainty', 'Conflicting Data')." },
          "suggestion": { "type": "string", "description": "What the human reviewer should specifically verify." }
        },
        "required": ["topic", "reason", "suggestion"]
      }
    },
    "ready_for_human_review": { 
      "type": "boolean",
      "description": "True if the AI is confident in its overall assessment and no critical data is missing."
    },
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion_id": { "type": "string" },
          "criterion_name": { "type": "string" },
          "recommended_rating": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "supporting_evidence": { 
            "type": "string",
            "description": "Direct quotes or specific facts found in the application materials."
          },
          "missing_evidence": { 
            "type": "string",
            "description": "Specific information required by the rubric that was not found."
          },
          "needs_human_attention": {
            "type": "boolean",
            "description": "Set to true if there is conflicting evidence, high uncertainty, or an unusual edge case."
          },
          "draft_comment": { "type": "string" },
          "reviewer_override": { "type": "string", "default": "" }
        },
        "required": [
          "criterion_id", 
          "criterion_name", 
          "recommended_rating", 
          "confidence", 
          "supporting_evidence",
          "needs_human_attention"
        ]
      }
    }
  },
  "required": ["applicant_id", "overall_summary", "criteria", "ready_for_human_review"]
}
