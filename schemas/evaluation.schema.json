{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evaluation",
  "type": "object",
  "properties": {
    "applicant_id": { "type": "string" },
    "overall_summary": { "type": "string" },
    "criteria": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "criterion_id": { "type": "string" },
          "criterion_name": { "type": "string" },
          "recommended_rating": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "supporting_evidence": { "type": "string" },
          "missing_evidence": { "type": "string" },
          "draft_comment": { "type": "string" },
          "reviewer_override": { "type": "string", "default": "" }
        },
        "required": ["criterion_id", "criterion_name", "recommended_rating", "confidence", "supporting_evidence"]
      }
    }
  },
  "required": ["applicant_id", "overall_summary", "criteria"]
}
